# ============================================================
# SCA-TESCHA Server — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# Base de datos MariaDB/MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CONTRASEÑA-DE-MARIADB-ROOT
DB_NAME=sca_tescha
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres
JWT_EXPIRES_IN=24h

# Servidor
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Rate Limiting (bloqueo por intentos fallidos)
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=15
